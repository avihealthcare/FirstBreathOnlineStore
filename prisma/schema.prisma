generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  ONLINE_PENDING
  BANK_TRANSFER
  PURCHASE_ORDER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SEOEntityType {
  PRODUCT
  CATEGORY
  PAGE
}

enum BannerPosition {
  HOME_HERO
  HOME_BULK
  PRODUCT_LIST
  CHECKOUT
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  passwordHash  String?
  role          UserRole @default(STAFF)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Customer {
  id                    String            @id @default(cuid())
  fullName              String?
  mobile                String?           @unique
  email                 String?           @unique
  passwordHash          String?
  hospitalName          String?
  gstNumber             String?
  billingAddress        String?
  savedProductSlugs     String[]          @default([])
  recentlyPurchasedSlugs String[]         @default([])
  addresses             CustomerAddress[]
  carts                 Cart[]
  orders                Order[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([mobile])
  @@index([email])
}

model CustomerAddress {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String   @default("India")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String
  image       String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  products    Product[]
  seoSettings SEOSetting[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Product {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  sku              String           @unique
  shortDescription String
  longDescription  String
  price            Decimal          @db.Decimal(10, 2)
  salePrice        Decimal?         @db.Decimal(10, 2)
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  tags             String[]         @default([])
  features         String[]         @default([])
  variants         ProductVariant[]
  images           ProductImage[]
  stockQuantity    Int              @default(0)
  shippingDetails  String
  availability     String           @default("In stock")
  rating           Decimal          @default(4.7) @db.Decimal(2, 1)
  reviewCount      Int              @default(0)
  isFeatured       Boolean          @default(false)
  isNewArrival     Boolean          @default(false)
  isBestSeller     Boolean          @default(false)
  popularity       Int              @default(0)
  status           ProductStatus    @default(PUBLISHED)
  similarProducts  Product[]        @relation("SimilarProducts")
  similarTo        Product[]        @relation("SimilarProducts")
  cartItems        CartItem[]
  orderItems       OrderItem[]
  seoSettings      SEOSetting[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int     @default(0)
}

model ProductVariant {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  value          String
  priceDelta     Decimal @default(0) @db.Decimal(10, 2)
  stockQuantity  Int     @default(0)
  compatibility  String?
  sterile        Boolean @default(true)
}

model Cart {
  id         String     @id @default(cuid())
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([customerId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String?
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  mobile          String
  email           String?
  hospitalName    String?
  gstNumber       String?
  billingAddress  String?
  shippingAddress Json
  items           OrderItem[]
  subtotal        Decimal       @db.Decimal(10, 2)
  discountCode    String?
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @db.Decimal(10, 2)
  shipping        Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(PURCHASE_ORDER)
  paymentStatus   PaymentStatus @default(PENDING)
  purchaseType    String        @default("Hospital Purchase")
  internalNotes   String?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  sku         String
  variant     String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
}

model Testimonial {
  id           String   @id @default(cuid())
  quote        String
  authorName   String
  authorTitle  String
  hospitalName String?
  rating       Int      @default(5)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Banner {
  id          String         @id @default(cuid())
  title       String
  subtitle    String?
  ctaLabel    String?
  ctaHref     String?
  image       String?
  discountText String?
  position    BannerPosition @default(HOME_BULK)
  isActive    Boolean        @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model HomepageContent {
  id                String   @id @default(cuid())
  eyebrow           String
  headline          String
  subheadline       String
  primaryCtaLabel   String
  primaryCtaHref    String
  secondaryCtaLabel String
  secondaryCtaHref  String
  image             String
  imageAlt          String
  calloutTitle      String
  calloutText       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PaymentOptionSetting {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String
  description   String
  isActive      Boolean  @default(true)
  bankName      String?
  accountName   String?
  accountNumber String?
  ifsc          String?
  branch        String?
  instructions  String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DiscountCoupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  type          String
  value         Decimal  @db.Decimal(10, 2)
  minOrderValue Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SEOSetting {
  id              String        @id @default(cuid())
  entityType      SEOEntityType
  entityId        String?
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug            String
  seoTitle        String
  metaDescription String
  keywords        String[]      @default([])
  openGraphImage  String?
  canonicalUrl    String?
  shouldIndex     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([entityType, slug])
}

model StoreSetting {
  id                String   @id @default(cuid())
  companyName       String   @default("AVI Healthcare Pvt Ltd")
  companyAddress    String
  contactEmail      String
  phoneNumber       String
  whatsappNumber    String?
  gstNumber         String?
  socialLinks       Json?
  footerText        String
  privacyPolicy     String
  termsAndConditions String
  shippingPolicy    String
  returnPolicy      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

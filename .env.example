# Supabase Postgres connection for Prisma migrations and server-side data access.
# Recommended by Supabase: create a dedicated "prisma" database user and use the
# Supavisor session-pooler connection string for DATABASE_URL.
DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Public Supabase values, only needed once the mock data layer is replaced.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-publishable-key"

# Server-only keys. Never expose these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="replace-on-server-only"
NEXTAUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_ACCESS_CODE="AVI-FIRSTBREATH-ADMIN"
ADMIN_SESSION_SECRET="replace-with-random-admin-session-secret"

# Future integrations.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
SMS_PROVIDER="mock"
OTP_FIXED_CODE="123456"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
